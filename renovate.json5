{
  extends: [
    "config:best-practices"
  ],
  dependencyDashboard: false,
  minimumReleaseAge: "3 days",
  lockFileMaintenance: {
    minimumReleaseAge: null,
    addLabels: [
      "automerge"
    ]
  },
  vulnerabilityAlerts: {
    minimumReleaseAge: null,
    addLabels: [
      "automerge"
    ]
  },
  packageRules: [
    {
      matchUpdateTypes: [
        "minor",
        "patch"
      ],
      groupName: "all minor and patch updates",
      groupSlug: "all-minor-and-patch-updates",
      addLabels: [
        "automerge"
      ]
    },
    {
      matchManagers: [
        "github-actions"
      ],
      minimumReleaseAge: "7 days"
    },
    {
      matchUpdateTypes: [
        "digest",
        "pinDigest"
      ],
      addLabels: [
        "automerge"
      ]
    }
  ]
}
